{
  "name": "project-recorder",
  "version": "1.0.0",
  "description": "Single-page speech-to-text workspace tool",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node -e \"console.log('No build step: Cloudflare serves ./public and ./functions directly')\"",
    "deploy": "npx wrangler pages deploy public",
    "cf:dev": "npx wrangler pages dev public --kv=RECORDER_KV",
    "cf:deploy": "npx wrangler pages deploy public",
    "cf:kv:create": "npx wrangler kv namespace create RECORDER_KV"
  },
  "dependencies": {
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  }
}
